// Формирует отчет о прогоне в формате JSON: статистика тестов, полный список
// тестов, проблемы (упавшие и сломанные тесты и наборы) и пропущенные тесты
// с причинами. Отчет машиночитаемый, используется MCP-инструментами (src/mcp)
// и исполнителем изоляции для вклейки результатов дочерних прогонов.

#Использовать collectionos
#Использовать "../../../shared"

Перем _ПутьКОтчету;        // Строка - Путь к формируемому файлу отчета

Перем _РепортерСтатистика; // РепортерСтатистика - Статистика текущего прогона

&ПодпискаНаСобытие("ИсполнениеТестПланКонец")
Процедура ИсполнениеТестПланКонец(ТестПлан) Экспорт

	Если Не ЗначениеЗаполнено(_ПутьКОтчету) Тогда
		Возврат;
	КонецЕсли;

	ВывестиТестПлан(ТестПлан);

КонецПроцедуры

Процедура ВывестиТестПлан(ТестПлан)

	Проблемы    = Новый Массив();
	Пропущенные = Новый Массив();
	Тесты       = Новый Массив();

	Для Каждого Набор Из ТестПлан.Дети() Цикл
		ОбработатьНабор(Набор, Набор.Имя(), Проблемы, Пропущенные, Тесты);
	КонецЦикла;

	Отчет = Новый Структура();
	Отчет.Вставить("statistics", Статистика());
	Отчет.Вставить("problems", Проблемы);
	Отчет.Вставить("skipped_tests", Пропущенные);
	Отчет.Вставить("tests", Тесты);

	ЗаписьJSON = Новый ЗаписьJSON();
	ЗаписьJSON.ОткрытьФайл(_ПутьКОтчету);
	ЗаписатьJSON(ЗаписьJSON, Отчет);
	ЗаписьJSON.Закрыть();

КонецПроцедуры

Процедура ОбработатьНабор(Определение, Знач ИмяНабора, Проблемы, Пропущенные, Тесты)

	Результат = _РепортерСтатистика.Результат(Определение);
	Состояние = Результат.Состояние();

	Если Состояние = СостоянияВыполненияТестов.Ошибка
		Или Состояние = СостоянияВыполненияТестов.Сломан Тогда

		// Набор не был выполнен - тесты внутри не имеют результатов
		Проблемы.Добавить(Проблема(Определение.ПолноеИмя(), Неопределено, Результат));

	ИначеЕсли Состояние = СостоянияВыполненияТестов.Пропущен
		Или Состояние = СостоянияВыполненияТестов.Прерван Тогда

		Пропущенные.Добавить(Пропуск(Определение.ПолноеИмя(), Неопределено, Результат));

	Иначе

		Для Каждого Дитя Из Определение.Дети() Цикл

			Если Дитя.ТипОпределения() = ТипыОпределенийТестов.Контейнер Тогда
				ОбработатьНабор(Дитя, ИмяНабора, Проблемы, Пропущенные, Тесты);
			Иначе
				ОбработатьТест(Дитя, ИмяНабора, Проблемы, Пропущенные, Тесты);
			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

Процедура ОбработатьТест(Тест, Знач ИмяНабора, Проблемы, Пропущенные, Тесты)

	Результат = _РепортерСтатистика.Результат(Тест);
	Состояние = Результат.Состояние();

	Тесты.Добавить(ЗаписьТеста(ИмяНабора, Тест, Результат));

	Если Состояние = СостоянияВыполненияТестов.Ошибка
		Или Состояние = СостоянияВыполненияТестов.Сломан Тогда

		Проблемы.Добавить(Проблема(ИмяНабора, Тест.Имя(), Результат));

	ИначеЕсли Состояние = СостоянияВыполненияТестов.Пропущен
		Или Состояние = СостоянияВыполненияТестов.Прерван Тогда

		Пропущенные.Добавить(Пропуск(ИмяНабора, Тест.Имя(), Результат));

	КонецЕсли;

КонецПроцедуры

Функция ЗаписьТеста(Знач ИмяНабора, Тест, Результат)

	Запись = ЗаписьОтчета(ИмяНабора, Тест.Имя(), Результат);

	Запись.Вставить(
		"duration_ms",
		_РепортерСтатистика.СтатистикаТеста(Тест).ПолучитьИлиУмолчание("ВремяВыполнения", 0)
	);

	Если Результат.Состояние() = СостоянияВыполненияТестов.Ошибка
		Или Результат.Состояние() = СостоянияВыполненияТестов.Сломан Тогда

		// Подробности со стеками есть только у проблем -
		// причины пропусков и прерываний описываются строками
		Запись.Вставить("message", ОписанияПричин(Результат));
		Запись.Вставить("details", ПодробныеПричины(Результат));

	ИначеЕсли Результат.Состояние() <> СостоянияВыполненияТестов.Успех Тогда
		Запись.Вставить("message", ОписанияПричин(Результат));
	КонецЕсли; // BSLLS:IfElseIfEndsWithElse-off

	Если Не ПустаяСтрока(Результат.Вывод()) Тогда
		Запись.Вставить("output", Результат.Вывод());
	КонецЕсли;

	Возврат Запись;

КонецФункции

Функция Статистика()

	СтатистикаПлана = _РепортерСтатистика.СтатистикаТестПлана();

	Статистика = Новый Структура();

	Статистика.Вставить("total",       СтатистикаПлана.ПолучитьИлиУмолчание("ТестовОбнаружено", 0));
	Статистика.Вставить("passed",      СтатистикаПлана.ПолучитьИлиУмолчание("ТестовУспешно", 0));
	Статистика.Вставить("failed",      СтатистикаПлана.ПолучитьИлиУмолчание("ТестовОшибка", 0));
	Статистика.Вставить("broken",      СтатистикаПлана.ПолучитьИлиУмолчание("ТестовСломано", 0));
	Статистика.Вставить("skipped",     СтатистикаПлана.ПолучитьИлиУмолчание("ТестовПропущено", 0));
	Статистика.Вставить("aborted",     СтатистикаПлана.ПолучитьИлиУмолчание("ТестовПрервано", 0));
	Статистика.Вставить("duration_ms", СтатистикаПлана.ПолучитьИлиУмолчание("ВремяВыполнения", 0));

	Возврат Статистика;

КонецФункции

Функция Проблема(Знач ИмяНабора, Знач ИмяТеста, Результат)

	Проблема = ЗаписьОтчета(ИмяНабора, ИмяТеста, Результат);

	Проблема.Вставить("message", ОписанияПричин(Результат));
	Проблема.Вставить("details", ПодробныеПричины(Результат));

	Возврат Проблема;

КонецФункции

Функция Пропуск(Знач ИмяНабора, Знач ИмяТеста, Результат)

	Пропуск = ЗаписьОтчета(ИмяНабора, ИмяТеста, Результат);

	Пропуск.Вставить("reason", ОписанияПричин(Результат));

	Возврат Пропуск;

КонецФункции

Функция ЗаписьОтчета(Знач ИмяНабора, Знач ИмяТеста, Результат)

	Запись = Новый Структура();

	Запись.Вставить("status", СтатусСостояния(Результат.Состояние()));
	Запись.Вставить("suite", ИмяНабора);

	Если ИмяТеста <> Неопределено Тогда
		Запись.Вставить("test", ИмяТеста);
	КонецЕсли;

	Возврат Запись;

КонецФункции

Функция ОписанияПричин(Результат)

	Возврат СтрСоединить(Результат.ОписанияПричин().ВМассив(), Символы.ПС);

КонецФункции

Функция ПодробныеПричины(Результат)

	Возврат Результат.Причины()
		.ПроцессорКоллекции()
		.Обработать("Причина -> ТестированиеСлужебный.ПодробноеОписаниеОшибки(""Причина"", Причина)")
		.ВСтроку(Символы.ПС);

КонецФункции

Функция СтатусСостояния(Знач Состояние)

	Если Состояние = СостоянияВыполненияТестов.Ошибка Тогда
		Возврат "failed";
	ИначеЕсли Состояние = СостоянияВыполненияТестов.Сломан Тогда
		Возврат "broken";
	ИначеЕсли Состояние = СостоянияВыполненияТестов.Пропущен Тогда
		Возврат "skipped";
	ИначеЕсли Состояние = СостоянияВыполненияТестов.Прерван Тогда
		Возврат "aborted";
	Иначе
		Возврат "passed";
	КонецЕсли;

КонецФункции

&Желудь
Процедура ПриСозданииОбъекта(&Блестяшка ПутьКОтчетуJSON, &Пластилин РепортерСтатистика)
	_ПутьКОтчету        = ПутьКОтчетуJSON;
	_РепортерСтатистика = РепортерСтатистика;
КонецПроцедуры
