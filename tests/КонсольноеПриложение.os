// Тесты служебного кода консольного приложения (src/cli/internal)
//
// Внимание: у этого сценария намеренно нет конструктора с аннотацией &ТестовыйНабор,
// см. пояснение в Исполнитель.os

#Использовать asserts
#Использовать tempfiles
#Использовать logos
#Использовать collectionos
#Использовать "./support"
#Использовать ".."
#Использовать "../src/cli/internal"
#Использовать "../src/cli/internal/isolated"

#Область ТестыРежимаВыводаЛога

&ПараметризованныйТест
&ИсточникЗначение("none", "Ничего")
&ИсточникЗначение("summary", "Статистика")
&ИсточникЗначение("flat", "ПлоскийСписок")
&ИсточникЗначение("tree", "Дерево")
&ИсточникЗначение("TREE", "Дерево")
Процедура РежимВыводаЛогаРаспознается(Режим, Ожидаемый) Экспорт

	Ожидаем.Что(КонсольноеПриложениеТестированиеСлужебный.РежимВыводаЛога(Режим))
		.Равно(Ожидаемый);

КонецПроцедуры

&Тест
Процедура НеизвестныйРежимВыводаВызываетИсключение() Экспорт

	Попытка
		КонсольноеПриложениеТестированиеСлужебный.РежимВыводаЛога("nonsense");
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
	КонецПопытки;

	Ожидаем.Что(ИнформацияОбОшибке).Не_().ЭтоНеопределено();
	Ожидаем.Что(СтрНайти(ИнформацияОбОшибке.Описание, "Неизвестный режим вывода")).Больше(0);

КонецПроцедуры

#КонецОбласти

#Область ТестыНастроекЛогоса

&Тест
Процедура НастройкиЛогосаСтроятсяПоКомпонентуИРаскладке() Экспорт

	Настройки = КонсольноеПриложениеТестированиеСлужебный.НастройкиЛогоса("core", "МояРаскладка");

	Логгер = Настройки.Получить("logos.logger").Получить("oscript.lib.oneunit.core");

	Ожидаем.Что(Логгер.Получить("level")).Равно("DEFAULT");
	Ожидаем.Что(Логгер.Получить("classlayout")).Равно("МояРаскладка");

КонецПроцедуры

#КонецОбласти

#Область ТестыКонфигурационногоФайла

&Тест
Процедура ЧтениеКонфигурационногоФайлаФильтруетНесуществующиеКаталоги() Экспорт

	МенеджерВременныхФайлов = Новый МенеджерВременныхФайлов();
	Каталог = МенеджерВременныхФайлов.СоздатьКаталог();

	ПутьКФайлу = ОбъединитьПути(Каталог, "oscript.cfg");

	ЗаписьТекста = Новый ЗаписьТекста(ПутьКФайлу);
	ЗаписьТекста.ЗаписатьСтроку("lib.additional=.;каталог_которого_нет");
	ЗаписьТекста.ЗаписатьСтроку("lib.system=каталог_которого_тоже_нет");
	ЗаписьТекста.ЗаписатьСтроку("custom.key=Значение");
	ЗаписьТекста.Закрыть();

	Результат = КонсольноеПриложениеТестированиеСлужебный.ПрочитатьКонфигурационныйФайл(ПутьКФайлу);

	// Произвольные ключи читаются как есть
	Ожидаем.Что(Результат.ПолучитьИлиУмолчание("custom.key", "")).Равно("Значение");

	// Несуществующий lib.system отброшен
	Ожидаем.Что(Результат.СодержитКлюч("lib.system")).ЭтоЛожь();

	// Из lib.additional отфильтрован несуществующий каталог,
	// а существующий нормализован относительно каталога конфигурационного файла
	ДополнительныеКаталоги = Результат.ПолучитьИлиУмолчание("lib.additional", Неопределено);

	Ожидаем.Что(ДополнительныеКаталоги.Количество()).Равно(1);

	МенеджерВременныхФайлов.Удалить();

КонецПроцедуры

#КонецОбласти

#Область ТестыТочкиВхода

&Тест
Процедура ТочкаВходаСобираетсяИзИмпортовТестов() Экспорт

	МенеджерВременныхФайлов = Новый МенеджерВременныхФайлов();
	МенеджерВременныхФайлов.БазовыйКаталог = МенеджерВременныхФайлов.СоздатьКаталог();

	ФайлыТестов = Новый Массив;
	ФайлыТестов.Добавить("./tests/fixtures/cli/НаборСИмпортомOneUnit.os");

	// ФиксированныйМассив, чтобы закрепить поддержку обоих типов массивов в детальках
	Детальки = Детальки(Массивы.ИзЭлементов("./tests/fixtures"), ФайлыТестов);

	ТочкаВхода = КонсольноеПриложениеТестированиеСлужебный.СоздатьТочкуВхода(
		Детальки,
		МенеджерВременныхФайлов,
		Логирование.ПолучитьЛог("oscript.lib.oneunit.тесты"),
		"// тестовая команда"
	);

	Ожидаем.Что(Новый Файл(ТочкаВхода).Существует(), "Точка входа существует").ЭтоИстина();

	ТекстТочкиВхода = ПрочитатьФайл(ТочкаВхода);

	// Импорты фикстур перенесены в точку входа
	Ожидаем.Что(СтрНайти(ТекстТочкиВхода, "asserts"), "Импорт asserts").Больше(0);

	// Импорт самого oneunit пропускается
	Ожидаем.Что(СтрНайти(ТекстТочкиВхода, "#Использовать oneunit"), "Импорт oneunit пропущен").Равно(0);

	// Точка входа загружает сценарий запуска тестирования
	Ожидаем.Что(СтрНайти(ТекстТочкиВхода, "ЗагрузитьСценарий"), "ЗагрузитьСценарий").Больше(0);

	// Детальки выгружены в файл свойств поделки
	ФайлДеталек = ОбъединитьПути(МенеджерВременныхФайлов.БазовыйКаталог, "autumn-properties.json");

	Ожидаем.Что(Новый Файл(ФайлДеталек).Существует(), "Файл деталек существует").ЭтоИстина();

	ТекстДеталек = ПрочитатьФайл(ФайлДеталек);

	Ожидаем.Что(СтрНайти(ТекстДеталек, "КаталогиТестов")).Больше(0);
	Ожидаем.Что(СтрНайти(ТекстДеталек, "./tests/fixtures")).Больше(0);

	// Сформирован объединённый конфигурационный файл
	ФайлКонфигурации = ОбъединитьПути(МенеджерВременныхФайлов.БазовыйКаталог, "oscript.cfg");

	Ожидаем.Что(Новый Файл(ФайлКонфигурации).Существует(), "Конфигурационный файл существует").ЭтоИстина();

	МенеджерВременныхФайлов.Удалить();

КонецПроцедуры

&Тест
Процедура БезКаталоговИФайловИспользуетсяКаталогПоУмолчанию() Экспорт

	МенеджерВременныхФайлов = Новый МенеджерВременныхФайлов();
	МенеджерВременныхФайлов.БазовыйКаталог = МенеджерВременныхФайлов.СоздатьКаталог();

	Детальки = Детальки(Новый Массив, Новый Массив);

	КонсольноеПриложениеТестированиеСлужебный.СоздатьТочкуВхода(
		Детальки,
		МенеджерВременныхФайлов,
		Логирование.ПолучитьЛог("oscript.lib.oneunit.тесты"),
		"// тестовая команда"
	);

	КаталогиТестов = Детальки.Получить("КаталогиТестов");

	Ожидаем.Что(КаталогиТестов).ИмеетДлину(1);
	Ожидаем.Что(КаталогиТестов.Получить(0)).Равно("./tests");

	// Конфигурационный файл каталога тестов слит в общий:
	// tests/oscript.cfg указывает на локальный каталог библиотек
	ТекстКонфигурации = ПрочитатьФайл(ОбъединитьПути(МенеджерВременныхФайлов.БазовыйКаталог, "oscript.cfg"));

	Ожидаем.Что(СтрНайти(ТекстКонфигурации, "oscript_modules")).Больше(0);

	МенеджерВременныхФайлов.Удалить();

КонецПроцедуры

#КонецОбласти

#Область ТестыЛогаКоманды

&Тест
Процедура ЛогКомандыРазбираетJSONСообщения() Экспорт

	ДеталькиПоделки = Новый Соответствие;
	ДеталькиПоделки.Вставить("OneUnit.КаталогиТестов", "");
	ДеталькиПоделки.Вставить("OneUnit.ФайлыТестов", "");

	Поделка = ПрогоныТестов.СоздатьПоделку(ДеталькиПоделки);
	Лог     = Поделка.НайтиЖелудь("ЛогДляКомандыМенеджера");

	УровниВыводимые = СтрРазделить("INFO,WARN,ERROR,FATAL", ",");

	Буфер = Новый ПотокВПамяти();

	ТестированиеСлужебный.НачатьПерехватВывода(Буфер);

	Для каждого Уровень Из УровниВыводимые Цикл
		Лог.Информация(СтрШаблон("{""msg"": ""СообщениеУровня%1"", ""level"": ""%1""}", Уровень));
	КонецЦикла;

	// Отладочный уровень перебрасывается, но по умолчанию не выводится
	Лог.Информация("{""msg"": ""СообщениеУровняDEBUG"", ""level"": ""DEBUG""}");

	// Сообщения не в формате JSON перебрасываются как есть
	Лог.Ошибка("ПростоТекстОшибки");
	Лог.Информация("ПростоИнформационныйТекст");

	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	Буфер.СброситьБуферы();
	Буфер.Перейти(0);

	ЧтениеТекста = Новый ЧтениеТекста();
	ЧтениеТекста.Открыть(Буфер, Консоль.КодировкаВыходногоПотока);
	Вывод = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Для каждого Уровень Из УровниВыводимые Цикл
		Ожидаем.Что(СтрНайти(Вывод, "СообщениеУровня" + Уровень), "Сообщение уровня " + Уровень).Больше(0);
	КонецЦикла;

	Ожидаем.Что(СтрНайти(Вывод, "СообщениеУровняDEBUG")).Равно(0);
	Ожидаем.Что(СтрНайти(Вывод, "ПростоТекстОшибки")).Больше(0);
	Ожидаем.Что(СтрНайти(Вывод, "ПростоИнформационныйТекст")).Больше(0);

КонецПроцедуры

#КонецОбласти

#Область ТестыОписанияПриложения

&Тест
Процедура ОписаниеПриложенияЗаполнено() Экспорт

	Описание = Новый ОписаниеКонсольногоПриложения();

	Ожидаем.Что(Описание.ИмяПриложения()).Равно("OneUnit");
	Ожидаем.Что(Описание.ПолноеИмяПриложения()).Заполнено();
	Ожидаем.Что(Описание.ВерсияПриложения()).Заполнено();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция Детальки(КаталогиТестов, ФайлыТестов)

	Детальки = Новый Соответствие;
	Детальки.Вставить("КаталогиТестов", КаталогиТестов);
	Детальки.Вставить("ФайлыТестов", ФайлыТестов);
	Детальки.Вставить("ИскатьВПодкаталогах", Ложь);
	Детальки.Вставить("Таймаут", 0);
	Детальки.Вставить("РежимВыводаЛога", РежимыВыводаЛога.Дерево);

	Возврат Детальки;

КонецФункции

Функция ПрочитатьФайл(Путь)

	ЧтениеТекста = Новый ЧтениеТекста(Путь, КодировкаТекста.UTF8);
	Текст = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Возврат Текст;

КонецФункции

#КонецОбласти
