// Тесты исполнения тест плана: состояния, жизненный цикл, статистика, отчёты.
//
// Внимание: у этого сценария намеренно нет конструктора с аннотацией &ТестовыйНабор.
// Аннотированные типы видны всем поделкам процесса, и вложенная поделка
// зациклится, повторно исполняя этот же сценарий.

#Использовать asserts
#Использовать tempfiles
#Использовать "./support"
#Использовать ".."

&ПослеВсех
Процедура УдалитьВременныеФайлы() Экспорт
	ВременныеФайлы.Удалить();
КонецПроцедуры

#Область ТестыСтатистики

&Тест
Процедура СтатистикаНаборов() Экспорт

	Статистика = Прогон().Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовОбнаружено", 0)).Равно(21);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовПропущено", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовПрервано", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовСломано", 0)).Равно(6);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовОшибка", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовУспешно", 0)).Равно(11);

КонецПроцедуры

&Тест
Процедура СтатистикаТестов() Экспорт

	Статистика = Прогон().Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(72);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовПрервано", 0)).Равно(5);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОшибка", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(3);

	// Количество пропущенных зависит от версии OneScript
	// (аннотации ВключенДляOneScript/ВыключенДляOneScript в НаборСВыключеннымиТестами),
	// но сумма успешных и пропущенных инвариантна
	ТестовПропущено = Статистика.ПолучитьИлиУмолчание("ТестовПропущено", 0);
	ТестовУспешно   = Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0);

	Ожидаем.Что(ТестовПропущено).Между(7, 9);
	Ожидаем.Что(ТестовПропущено + ТестовУспешно).Равно(62);

КонецПроцедуры

&Тест
Процедура СтатистикаНабораСчитается() Экспорт

	Прогон    = Прогон();
	Набор     = ПрогоныТестов.НайтиНабор(Прогон.План, "Тест");
	Статистика = Прогон.Статистика.СтатистикаНабора(Набор);

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ВремяВыполнения", -1)).БольшеИлиРавно(0);

КонецПроцедуры

#КонецОбласти

