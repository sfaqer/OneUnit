#КонецОбласти

#Область ТестыУсловий

&Тест
Процедура БезусловноВыключенныеТестыПропускаются() Экспорт

	Результат = РезультатТеста("НаборСВыключеннымиТестами", "Выключен");

	Ожидаем.Что(Результат.Состояние()).Равно(СостоянияВыполненияТестов.Пропущен);
	Ожидаем.Что(Результат.ОписанияПричин().Получить(0)).Равно("На мне аннотация Выключен");

	Результат = РезультатТеста("НаборСВыключеннымиТестами", "ВыключенЕслиИстина");

	Ожидаем.Что(Результат.Состояние()).Равно(СостоянияВыполненияТестов.Пропущен);
	Ожидаем.Что(Результат.ОписанияПричин().Получить(0))
		.Равно("На мне аннотация ВыключенЕсли которая вернула истину");

	Результат = РезультатТеста("НаборСВыключеннымиТестами", "ВключенЕсли");

	Ожидаем.Что(Результат.Состояние()).Равно(СостоянияВыполненияТестов.Пропущен);
	Ожидаем.Что(Результат.ОписанияПричин().Получить(0))
		.Равно("На мне аннотация ВключенЕсли которая вернула Ложь");

КонецПроцедуры

&Тест
Процедура УсловияНаОперационнуюСистему() Экспорт

	// На любой ОС ровно один из трёх ВыключенНаОС срабатывает,
	// и ровно один из трёх ВключенНаОС разрешает выполнение
	Ожидаем.Что(КоличествоПропущенных(Списки.ИзЭлементов(
		"ВыключенНаОСWindows", "ВыключенНаОСLinux", "ВыключенНаОСMacOS"))).Равно(1);

	Ожидаем.Что(КоличествоПропущенных(Списки.ИзЭлементов(
		"ВключенНаОСWindows", "ВключенНаОСLinux", "ВключенНаОСMacOS"))).Равно(2);

КонецПроцедуры

&Тест
Процедура УсловияНаВерсиюOneScript() Экспорт

	// Результат зависит от версии движка, но тесты фикстуры самопроверяющиеся:
	// каждый либо пропущен условием, либо успешно проверил версию внутри себя
	ИменаТестов = Списки.ИзЭлементов(
		"ВыключенДляOneScriptМладшеДвойки",
		"ВыключенДляOneScriptСтаршеДвойки",
		"ВключенДляOneScriptМладшеДвойки",
		"ВключенДляOneScriptСтаршеДвойки"
	);

	Для каждого ИмяТеста Из ИменаТестов Цикл

		Состояние = РезультатТеста("НаборСВыключеннымиТестами", ИмяТеста).Состояние();

		Ожидаем.Что(
			Состояние = СостоянияВыполненияТестов.Успех
				Или Состояние = СостоянияВыполненияТестов.Пропущен,
			СтрШаблон("Состояние теста %1: %2", ИмяТеста, Состояние)
		).ЭтоИстина();

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ТестыОтчетов

&Тест
Процедура ОтчетыФормируются() Экспорт

	Прогон();

	ПроверитьОтчет(ПрогоныТестов.ВременныйПуть("ОтчетJUnit", "xml"), "<testsuites");
	ПроверитьОтчет(ПрогоныТестов.ВременныйПуть("ОтчетGenericExecution", "xml"), "<testExecutions");
	ПроверитьОтчет(ПрогоныТестов.ВременныйПуть("ОтчетOpenTestReport", "xml"), "<e:events");

КонецПроцедуры

&Тест
Процедура РежимПлоскогоЛогаРаботает() Экспорт

	Прогон = ПрогонПлоскогоЛога();

	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(11);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОшибка", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовПропущено", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура ПланОбнаруженияВыводитсяВЛог() Экспорт

	// Режим дерева: репортер основного прогона
	Прогон   = Прогон();
	Репортер = Прогон.Поделка.НайтиЖелудь("РепортерЛогДерево");

	Буфер = Новый ПотокВПамяти();

	ТестированиеСлужебный.НачатьПерехватВывода(Буфер);
	Репортер.ВывестиТестПлан(Прогон.План);
	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	Вывод = ПрогоныТестов.ПрочитатьПоток(Буфер);

	Ожидаем.Что(СтрНайти(Вывод, "НаборКомпанейский"), "Дерево содержит набор").Больше(0);
	Ожидаем.Что(СтрНайти(Вывод, "ИсточникЗначение"), "Дерево содержит контейнер").Больше(0);

	// Режим плоского списка: репортер прогона плоского лога
	Прогон   = ПрогонПлоскогоЛога();
	Репортер = Прогон.Поделка.НайтиЖелудь("РепортерЛогПлоскийСписок");

	Буфер = Новый ПотокВПамяти();

	ТестированиеСлужебный.НачатьПерехватВывода(Буфер);
	Репортер.ВывестиТестПлан(Прогон.План);
	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	Вывод = ПрогоныТестов.ПрочитатьПоток(Буфер);

	Ожидаем.Что(СтрНайти(Вывод, "Тест.Тест1"), "Плоский список содержит полное имя").Больше(0);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция Прогон()

	ВключаемыеНаборы = Новый Массив;
	ВключаемыеНаборы.Добавить("НаборБезКонструктора");
	ВключаемыеНаборы.Добавить("НаборВыключенный");
	ВключаемыеНаборы.Добавить("НаборКомпанейский");
	ВключаемыеНаборы.Добавить("НаборОдиночка");
	ВключаемыеНаборы.Добавить("НаборПадающий");
	ВключаемыеНаборы.Добавить("НаборПрерванный");
	ВключаемыеНаборы.Добавить("НаборСПрерваннымиТестами");
	ВключаемыеНаборы.Добавить("НаборПадающийВКонструкторе");
	ВключаемыеНаборы.Добавить("НаборКрасныхТестов");
	ВключаемыеНаборы.Добавить("НаборБезТестов");
	ВключаемыеНаборы.Добавить("СломанныйНабор");
	ВключаемыеНаборы.Добавить("ПовторяемыйТест");
	ВключаемыеНаборы.Добавить("ПараметризованныйТест");
	ВключаемыеНаборы.Добавить("Тест");
	ВключаемыеНаборы.Добавить("НаборСВыключеннымиТестами");
	ВключаемыеНаборы.Добавить("__Тест_Набор_Со_Странным_Именем_1");
	ВключаемыеНаборы.Добавить("НаборСТаймаутом");
	ВключаемыеНаборы.Добавить("НаборСВыводом");
	ВключаемыеНаборы.Добавить("НаборЖизненныйЦикл");
	ВключаемыеНаборы.Добавить("НаборСОшибкой");
	ВключаемыеНаборы.Добавить("НаборСПадающимУсловием");

	ФайлыТестов = Новый Массив;
	ФайлыТестов.Добавить("./tests/fixtures/execution/НаборСТаймаутом.os");
	ФайлыТестов.Добавить("./tests/fixtures/execution/НаборСВыводом.os");
	ФайлыТестов.Добавить("./tests/fixtures/execution/НаборЖизненныйЦикл.os");
	ФайлыТестов.Добавить("./tests/fixtures/execution/НаборСОшибкой.os");
	ФайлыТестов.Добавить("./tests/fixtures/execution/НаборСПадающимУсловием.os");

	ДопДетальки = Новый Соответствие;
	ДопДетальки.Вставить("OneUnit.РежимВыводаЛога", РежимыВыводаЛога.Дерево);
	ДопДетальки.Вставить(
		"OneUnit.ПутьКОтчетуJUnit",
		ПрогоныТестов.ВременныйПуть("ОтчетJUnit", "xml"));
	ДопДетальки.Вставить(
		"OneUnit.ПутьКОтчетуGenericExecution",
		ПрогоныТестов.ВременныйПуть("ОтчетGenericExecution", "xml"));
	ДопДетальки.Вставить(
		"OneUnit.ПутьКОтчетуOpenTestReport",
		ПрогоныТестов.ВременныйПуть("ОтчетOpenTestReport", "xml"));

	Возврат ПрогоныТестов.ПрогнатьОднажды(
		"ОсновнойПрогон",
		СтрСоединить(ВключаемыеНаборы, ","),
		"./tests/fixtures",
		СтрСоединить(ФайлыТестов, ","),
		ДопДетальки
	);

КонецФункции

Функция ПрогонПлоскогоЛога()

	ДопДетальки = Новый Соответствие;
	ДопДетальки.Вставить("OneUnit.РежимВыводаЛога", РежимыВыводаЛога.ПлоскийСписок);

	ФайлыТестов = Новый Массив;
	ФайлыТестов.Добавить("./tests/fixtures/Тест.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборКрасныхТестов.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборВыключенный.os");
	ФайлыТестов.Добавить("./tests/fixtures/ПовторяемыйТест.os");

	Возврат ПрогоныТестов.ПрогнатьОднажды(
		"ПлоскийЛог",
		"Тест,НаборКрасныхТестов,НаборВыключенный,ПовторяемыйТест",
		"",
		СтрСоединить(ФайлыТестов, ","),
		ДопДетальки
	);

КонецФункции

Функция РезультатТеста(ИмяНабора, ИмяТеста)

	Прогон = Прогон();
	Набор  = ПрогоныТестов.НайтиНабор(Прогон.План, ИмяНабора);

	Возврат Прогон.Статистика.Результат(ПрогоныТестов.НайтиТест(Набор, ИмяТеста));

КонецФункции

Функция РезультатНабора(ИмяНабора)

	Прогон = Прогон();

	Возврат Прогон.Статистика.Результат(ПрогоныТестов.НайтиНабор(Прогон.План, ИмяНабора));

КонецФункции

Функция СтатистикаНабора(ИмяНабора)

	Прогон = Прогон();

	Возврат Прогон.Статистика.СтатистикаНабора(ПрогоныТестов.НайтиНабор(Прогон.План, ИмяНабора));

КонецФункции

Функция КоличествоПропущенных(ИменаТестов)

	Количество = 0;

	Для каждого ИмяТеста Из ИменаТестов Цикл

		Результат = РезультатТеста("НаборСВыключеннымиТестами", ИмяТеста);

		Если Результат.Состояние() = СостоянияВыполненияТестов.Пропущен Тогда
			Количество = Количество + 1;
		Иначе
			Ожидаем.Что(Результат.Состояние()).Равно(СостоянияВыполненияТестов.Успех);
		КонецЕсли;

	КонецЦикла;

	Возврат Количество;

КонецФункции

Процедура ПроверитьСостоянияДетей(Прогон, Контейнер, ОжидаемыеСостояния)

	Ожидаем.Что(Контейнер.Дети()).ИмеетДлину(ОжидаемыеСостояния.Количество());

	Для Индекс = 0 По ОжидаемыеСостояния.Количество() - 1 Цикл

		Результат = Прогон.Статистика.Результат(Контейнер.Дети().Получить(Индекс));

		Ожидаем.Что(
			Результат.Состояние(),
			СтрШаблон("Состояние ребёнка %1 контейнера %2", Индекс, Контейнер.Имя())
		).Равно(ОжидаемыеСостояния.Получить(Индекс));

	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьОтчет(ПутьКОтчету, ОжидаемоеСодержимое)

	Ожидаем.Что(Новый Файл(ПутьКОтчету).Существует(), "Отчёт существует: " + ПутьКОтчету).ЭтоИстина();

	ЧтениеТекста = Новый ЧтениеТекста(ПутьКОтчету, КодировкаТекста.UTF8);
	Содержимое   = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Ожидаем.Что(Содержимое).Заполнено();

	Если ЗначениеЗаполнено(ОжидаемоеСодержимое) Тогда
		Ожидаем.Что(СтрНайти(Содержимое, ОжидаемоеСодержимое), "Содержимое отчёта " + ПутьКОтчету).Больше(0);
	КонецЕсли;

	// Отчёт должен быть корректным XML
	ЧтениеXML = Новый ЧтениеXML();
	ЧтениеXML.УстановитьСтроку(Содержимое);
	Пока ЧтениеXML.Прочитать() Цикл
		// чтение до конца документа, при некорректном XML будет выброшено исключение
	КонецЦикла;
	ЧтениеXML.Закрыть();

КонецПроцедуры

#КонецОбласти
