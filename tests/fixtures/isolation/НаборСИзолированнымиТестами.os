// Набор с изоляцией на уровне отдельных тестов: обычные тесты выполняются
// в общем потоке, изолированные - каждый в своем контексте, как будто набор
// прогнали только с этим тестом.

#Использовать asserts

Перем ОбщееСостояние;

&Тест
Процедура ОбычныйТестВидитОбщееСостояние() Экспорт
	ОбщееСостояние = "изменено";
	Ожидаем.Что(ОбщееСостояние).Равно("изменено");
КонецПроцедуры

&Тест
&Изолированный
Процедура ИзолированныйВПоделкеНеВидитОбщееСостояние() Экспорт
	// Свежая поделка - свежий экземпляр набора, без следов соседних тестов
	Ожидаем.Что(ОбщееСостояние).Равно("из-конструктора");
КонецПроцедуры

&Тест
&Изолированный(Уровень = "Процесс")
Процедура ИзолированныйВПроцессеВыполняется() Экспорт
	Ожидаем.Что(ОбщееСостояние).Равно("из-конструктора");
КонецПроцедуры

&ПовторяемыйТест(2)
&Изолированный
Процедура ИзолированныйПовторяемыйТест() Экспорт
	Ожидаем.Что(ОбщееСостояние).Равно("из-конструктора");
КонецПроцедуры

&ТестовыйНабор
Процедура ПриСозданииОбъекта()
	ОбщееСостояние = "из-конструктора";
КонецПроцедуры
