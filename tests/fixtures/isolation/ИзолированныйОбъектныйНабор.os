// Набор с советом, значение детальки которого - объект. Лямбда совета исполняется
// в дочернем процессе по месту, поэтому объект не пересекает границу процесса
// и доступен набору как обычная деталька.

#Использовать asserts
#Использовать "Модули"

Перем _Объект;

&ТестовыйНабор
&Изолированный(Уровень = "Процесс", Совет = "() -> ГенераторИзоляции.СоветСОбъектом()")
Процедура ПриСозданииОбъекта(&Деталька("Изоляция.Объект", ЗначениеПоУмолчанию = Неопределено) Объект) Экспорт
	_Объект = Объект;
КонецПроцедуры

&Тест
Процедура ОбъектСоветаДоступенВПроцессе() Экспорт
	Ожидаем.Что(ТипЗнч(_Объект)).Равно(Тип("СписокМассив"));
КонецПроцедуры
