#Использовать autumn
#Использовать collectionos

// Возвращает совет создания поделки с заданной деталькой - имитация фабрики
// конфигураций из тестов, которым нужна собственная поделка (как ГенераторДанных
// в autumn-data)
//
//  Возвращаемое значение:
//   СоветДругогоМастера - Совет со значением детальки "Изоляция.Значение"
//
Функция СоветСоЗначением() Экспорт

	Возврат Новый СоветДругогоМастера().ЗначенияДеталек(
		Соответствия.ИзЭлементов("Изоляция.Значение", "из-совета")
	);

КонецФункции

// Возвращает совет, подменяющий детальку фильтра наборов, - с ним дочерний
// прогон не обнаруживает ни одного набора
//
//  Возвращаемое значение:
//   СоветДругогоМастера - Совет с фильтром, не пропускающим ни один набор
//
Функция СоветНеВидящийНаборы() Экспорт

	Возврат Новый СоветДругогоМастера().ЗначенияДеталек(
		Соответствия.ИзЭлементов("OneUnit.ТестовыеНаборыВключаемые", "НетТакогоНабора")
	);

КонецФункции

// Возвращает совет со значением детальки - объектом: лямбда совета исполняется
// в среде изолированного прогона, поэтому объекты в детальках допустимы
// на любом уровне изоляции
//
//  Возвращаемое значение:
//   СоветДругогоМастера - Совет со значением-объектом
//
Функция СоветСОбъектом() Экспорт

	Возврат Новый СоветДругогоМастера().ЗначенияДеталек(
		Соответствия.ИзЭлементов("Изоляция.Объект", Новый СписокМассив)
	);

КонецФункции
