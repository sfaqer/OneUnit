// Набор, чья лямбда совета строит совет вызовом экспортного метода самого набора.
// На уровне "Процесс" экземпляр набора для захвата поднимается в дочернем процессе
// напрямую через Новый - это возможно, пока конструктор набора без параметров.

#Использовать asserts

&Деталька("Изоляция.Значение", ЗначениеПоУмолчанию = "не-задано")
Перем Значение;

&ТестовыйНабор
&Изолированный(Уровень = "Процесс", Совет = "() -> {
	|	ЗначенияДеталек = Новый Соответствие();
	|	ЗначенияДеталек.Вставить(""Изоляция.Значение"", ЗначениеИзМетода());
	|
	|	Возврат Новый СоветДругогоМастера().ЗначенияДеталек(ЗначенияДеталек);
	|}")
Процедура ПриСозданииОбъекта()
КонецПроцедуры

Функция ЗначениеИзМетода() Экспорт
	Возврат "из-метода-набора";
КонецФункции

&Тест
Процедура ЗначениеПриходитИзМетодаНабора() Экспорт
	Ожидаем.Что(Значение).Равно("из-метода-набора");
КонецПроцедуры
