#Использовать asserts
#Использовать "Модули"

Перем _Значение;

&ТестовыйНабор
&Изолированный(Уровень = "Процесс", Совет = "() -> ГенераторИзоляции.СоветСоЗначением()")
Процедура ПриСозданииОбъекта(&Деталька("Изоляция.Значение", ЗначениеПоУмолчанию = "не-задано") Значение) Экспорт
	_Значение = Значение;
КонецПроцедуры

&Тест
Процедура ЗначениеПриходитИзСоветаВПроцессе() Экспорт
	Ожидаем.Что(_Значение).Равно("из-совета");
КонецПроцедуры
