#Использовать asserts
#Использовать "Модули"

Перем _Значение;

&ТестовыйНабор
&Изолированный(Совет = "() -> ГенераторИзоляции.СоветСоЗначением()")
Процедура ПриСозданииОбъекта(&Деталька("Изоляция.Значение", ЗначениеПоУмолчанию = "не-задано") Значение) Экспорт
	_Значение = Значение;
КонецПроцедуры

&Тест
Процедура ЗначениеПриходитИзСовета() Экспорт
	Ожидаем.Что(_Значение).Равно("из-совета");
КонецПроцедуры
