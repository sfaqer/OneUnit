// Изолированный на уровне процесса набор, выключенный условием только
// в изолированной среде: пропуск уровня набора переносится из отчета
// дочернего прогона.

#Использовать asserts

Перем _ВИзоляции;

&Тест
Процедура ТестПропускаемогоНабора() Экспорт
	Ожидаем.Что(Истина).ЭтоИстина();
КонецПроцедуры

&ТестовыйНабор
&Изолированный(Уровень = "Процесс")
&ВыключенЕсли("() -> _ВИзоляции", Причина = "Набор пропускается в изолированной среде")
Процедура ПриСозданииОбъекта(&Деталька("OneUnit.ВыполняетсяВИзоляции", ЗначениеПоУмолчанию = Ложь) ВИзоляции) Экспорт
	_ВИзоляции = ВИзоляции;
КонецПроцедуры
