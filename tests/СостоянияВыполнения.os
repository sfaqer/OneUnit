// Тесты модуля СостоянияВыполненияТестов

#Использовать asserts
#Использовать logos
#Использовать ".."

&ПараметризованныйТест
&ИсточникJSON(
	"[
	|    {""Первое"": ""Успех"",    ""Второе"": ""Успех"",    ""Ожидаемое"": ""Успех""},
	|    {""Первое"": ""Успех"",    ""Второе"": ""Пропущен"", ""Ожидаемое"": ""Пропущен""},
	|    {""Первое"": ""Пропущен"", ""Второе"": ""Прерван"",  ""Ожидаемое"": ""Прерван""},
	|    {""Первое"": ""Прерван"",  ""Второе"": ""Ошибка"",   ""Ожидаемое"": ""Ошибка""},
	|    {""Первое"": ""Ошибка"",   ""Второе"": ""Сломан"",   ""Ожидаемое"": ""Сломан""},
	|    {""Первое"": ""Сломан"",   ""Второе"": ""Успех"",    ""Ожидаемое"": ""Сломан""},
	|    {""Первое"": ""Пропущен"", ""Второе"": ""Успех"",    ""Ожидаемое"": ""Пропущен""},
	|    {""Первое"": ""Ошибка"",   ""Второе"": ""Прерван"",  ""Ожидаемое"": ""Ошибка""}
	|]"
)
Процедура НаихудшееСостояниеВыбираетсяПоПриоритету(Первое, Второе, Ожидаемое) Экспорт

	Ожидаем.Что(СостоянияВыполненияТестов.НаихудшееСостояние(Первое, Второе)).Равно(Ожидаемое);

	// Наихудшее состояние коммутативно
	Ожидаем.Что(СостоянияВыполненияТестов.НаихудшееСостояние(Второе, Первое)).Равно(Ожидаемое);

КонецПроцедуры

&Тест
Процедура УровеньЛогаСоответствуетСостоянию() Экспорт

	Ожидаем.Что(СостоянияВыполненияТестов.УровеньЛогаСостояния(СостоянияВыполненияТестов.Успех))
		.Равно(УровниЛога.Информация);

	Ожидаем.Что(СостоянияВыполненияТестов.УровеньЛогаСостояния(СостоянияВыполненияТестов.Пропущен))
		.Равно(УровниЛога.Предупреждение);

	Ожидаем.Что(СостоянияВыполненияТестов.УровеньЛогаСостояния(СостоянияВыполненияТестов.Прерван))
		.Равно(УровниЛога.Предупреждение);

	Ожидаем.Что(СостоянияВыполненияТестов.УровеньЛогаСостояния(СостоянияВыполненияТестов.Ошибка))
		.Равно(УровниЛога.Ошибка);

	Ожидаем.Что(СостоянияВыполненияТестов.УровеньЛогаСостояния(СостоянияВыполненияТестов.Сломан))
		.Равно(УровниЛога.Ошибка);

КонецПроцедуры

&ПараметризованныйТест
&ИсточникПеречисление("СостоянияВыполненияТестов")
Процедура СимволСостоянияОпределенДляКаждогоСостояния(Состояние) Экспорт

	Символ = СостоянияВыполненияТестов.СимволСостояния(Состояние);

	Ожидаем.Что(Символ).ИмеетТип("Строка").ИмеетДлину(1);
	Ожидаем.Что(СтрНайти("✔↷⊚✘⊝VО0X-", Символ)).Больше(0);

КонецПроцедуры
