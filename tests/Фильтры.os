// Тесты фильтрации обнаружения тестов по тегам, именам методов и наборов.
//
// Внимание: у этого сценария намеренно нет конструктора с аннотацией &ТестовыйНабор,
// см. пояснение в Исполнитель.os

#Использовать asserts
#Использовать "./support"
#Использовать ".."

#Область ТестыФильтраТегов

&Тест
Процедура ВключениеПоТегуОставляетТолькоПомеченныеТесты() Экспорт

	План = Обнаружить("OneUnit.ТегиВключаемые", "Параметризованный");

	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПараметризованныйТест").Дети()).ИмеетДлину(7);
	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПовторяемыйТест").Дети()).ИмеетДлину(0);
	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "Тест").Дети()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ВключениеПоТегуМетода() Экспорт

	План  = Обнаружить("OneUnit.ТегиВключаемые", "ОтображаемоеИмя");
	Набор = ПрогоныТестов.НайтиНабор(План, "ПовторяемыйТест");

	Ожидаем.Что(Набор.Дети()).ИмеетДлину(1);
	Ожидаем.Что(Набор.Дети().Получить(0).ИмяМетода()).Равно("ТриРазаИменнойИменованный");

КонецПроцедуры

&Тест
Процедура ИсключениеПоТегуУбираетПомеченныеТесты() Экспорт

	План = Обнаружить("OneUnit.ТегиИсключаемые", "Параметризованный");

	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПараметризованныйТест").Дети()).ИмеетДлину(0);
	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПовторяемыйТест").Дети()).ИмеетДлину(3);
	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "Тест").Дети()).ИмеетДлину(2);

КонецПроцедуры

#КонецОбласти

#Область ТестыФильтраМетодов

&Тест
Процедура ВключениеПоИмениМетода() Экспорт

	План = Обнаружить("OneUnit.ТестовыеМетодыВключаемые", "Тест1");

	Набор = ПрогоныТестов.НайтиНабор(План, "Тест");

	Ожидаем.Что(Набор.Дети()).ИмеетДлину(1);
	Ожидаем.Что(Набор.Дети().Получить(0).ИмяМетода()).Равно("Тест1");

	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПараметризованныйТест").Дети()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ВключениеПоРегулярномуВыражениюМетода() Экспорт

	План = Обнаружить("OneUnit.ТестовыеМетодыВключаемые", "Тест.");

	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "Тест").Дети()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ИсключениеПоИмениМетода() Экспорт

	План = Обнаружить("OneUnit.ТестовыеМетодыИсключаемые", "Тест1");

	Набор = ПрогоныТестов.НайтиНабор(План, "Тест");

	Ожидаем.Что(Набор.Дети()).ИмеетДлину(1);
	Ожидаем.Что(Набор.Дети().Получить(0).ИмяМетода()).Равно("Тест2");

	// Наборы без метода Тест1 не затронуты
	Ожидаем.Что(ПрогоныТестов.НайтиНабор(План, "ПовторяемыйТест").Дети()).ИмеетДлину(3);

КонецПроцедуры

&Тест
Процедура КомбинацияВключенияИИсключенияМетодов() Экспорт

	Детальки = Новый Соответствие;
	Детальки.Вставить("OneUnit.ТестовыеМетодыВключаемые", "Тест1|Тест2");
	Детальки.Вставить("OneUnit.ТестовыеМетодыИсключаемые", "Тест2");

	План  = ОбнаружитьПоДеталькам(Детальки);
	Набор = ПрогоныТестов.НайтиНабор(План, "Тест");

	Ожидаем.Что(Набор.Дети()).ИмеетДлину(1);
	Ожидаем.Что(Набор.Дети().Получить(0).ИмяМетода()).Равно("Тест1");

КонецПроцедуры

#КонецОбласти

#Область ТестыФильтраНаборов

&Тест
Процедура ВключениеПоИмениНабора() Экспорт

	План = Обнаружить("OneUnit.ТестовыеНаборыВключаемые", "Тест");

	Ожидаем.Что(План.Дети()).ИмеетДлину(1);
	Ожидаем.Что(План.Дети().Получить(0).Имя()).Равно("Тест");

КонецПроцедуры

&Тест
Процедура ВключениеПоРегулярномуВыражениюНабора() Экспорт

	План = Обнаружить("OneUnit.ТестовыеНаборыВключаемые", "Набор.*");

	Ожидаем.Что(План.Дети()).ИмеетДлину(11);

КонецПроцедуры

&Тест
Процедура ИсключениеПоИмениНабора() Экспорт

	План = Обнаружить("OneUnit.ТестовыеНаборыИсключаемые", "Тест,ПараметризованныйТест");

	Ожидаем.Что(План.Дети()).ИмеетДлину(14);

	Для каждого Набор Из План.Дети() Цикл
		Ожидаем.Что(Набор.Имя()).Не_().Равно("Тест");
		Ожидаем.Что(Набор.Имя()).Не_().Равно("ПараметризованныйТест");
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция Обнаружить(ИмяДетальки, ЗначениеДетальки)

	Детальки = Новый Соответствие;
	Детальки.Вставить(ИмяДетальки, ЗначениеДетальки);

	Возврат ОбнаружитьПоДеталькам(Детальки);

КонецФункции

Функция ОбнаружитьПоДеталькам(Детальки)

	Детальки.Вставить("OneUnit.КаталогиТестов", "./tests/fixtures");

	Поделка = ПрогоныТестов.СоздатьПоделку(Детальки);

	Возврат Поделка.НайтиЖелудь("МенеджерТестирования").Обнаружить();

КонецФункции

#КонецОбласти
