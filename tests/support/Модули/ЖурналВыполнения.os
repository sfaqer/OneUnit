// Глобальный журнал вызовов методов жизненного цикла тестовых наборов.
// Используется фикстурами исполнения для регистрации порядка вызовов,
// так как компанейские наборы не сохраняют состояние между методами.

Перем Записи Экспорт; // Массив - метки вызовов в порядке выполнения

Процедура Записать(Метка) Экспорт
	Записи.Добавить(Метка);
КонецПроцедуры

Процедура Очистить() Экспорт
	Записи = Новый Массив;
КонецПроцедуры

Записи = Новый Массив;
