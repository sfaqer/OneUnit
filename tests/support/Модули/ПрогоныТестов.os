// Вспомогательный модуль для тестов, выполняющих вложенные прогоны фреймворка.
//
// Важно: тестовые сценарии и фикстуры, создающие поделки, не должны иметь
// конструкторов с аннотацией &ТестовыйНабор — аннотированные типы видны
// всем поделкам процесса, и вложенная поделка зациклится, исполняя сам тест.
// По этой же причине во вложенные поделки всегда передаётся включающий
// фильтр тестовых наборов.

#Использовать tempfiles
#Использовать "../../.."

Перем КэшПрогонов; // Соответствие - кэш результатов прогонов по ключу
Перем КэшПутей;    // Соответствие - кэш имён временных файлов по ключу

// Создаёт поделку с переданными детальками и запускает приложение
//
// Параметры:
//  Детальки - Соответствие - Значения деталек поделки
//
// Возвращаемое значение:
//  Поделка - Запущенная поделка
//
Функция СоздатьПоделку(Детальки) Экспорт

	Поделка = Новый Поделка(Новый СоветДругогоМастера().ЗначенияДеталек(Детальки));
	Поделка.ЗапуститьПриложение();

	Возврат Поделка;

КонецФункции

// Выполняет вложенный прогон тестов и возвращает его результаты
//
// Параметры:
//  ВключаемыеНаборы - Строка - Включающий фильтр имён наборов через запятую
//  КаталогиТестов   - Строка - Каталоги поиска тестов через запятую
//  ФайлыТестов      - Строка - Файлы тестов через запятую
//  ДопДетальки      - Соответствие из КлючИЗначение - Дополнительные детальки поделки:
//   * Ключ     - Строка - Имя детальки с префиксом "OneUnit.", например "OneUnit.ПутьКОтчетуJSON"
//   * Значение - Строка - Значение детальки
//
// Возвращаемое значение:
//  Структура - Результаты прогона:
//   * Поделка    - Поделка - Поделка вложенного прогона
//   * Статистика - РепортерСтатистика - Желудь статистики прогона
//   * План       - ТестПлан - Выполненный тест-план
//
Функция Прогнать(ВключаемыеНаборы, КаталогиТестов = "", ФайлыТестов = "", ДопДетальки = Неопределено) Экспорт

	Детальки = Новый Соответствие;
	Детальки.Вставить("OneUnit.КаталогиТестов", КаталогиТестов);
	Детальки.Вставить("OneUnit.ФайлыТестов", ФайлыТестов);
	Детальки.Вставить("OneUnit.ТестовыеНаборыВключаемые", ВключаемыеНаборы);

	Если ДопДетальки <> Неопределено Тогда
		Для каждого Деталька Из ДопДетальки Цикл
			Детальки.Вставить(Деталька.Ключ, Деталька.Значение);
		КонецЦикла;
	КонецЕсли;

	Поделка = СоздатьПоделку(Детальки);

	Результат = Новый Структура;
	Результат.Вставить("Поделка", Поделка);
	Результат.Вставить("Статистика", Поделка.НайтиЖелудь("РепортерСтатистика"));
	Результат.Вставить("План", Поделка.НайтиЖелудь("МенеджерТестирования").Тестировать());

	Возврат Результат;

КонецФункции

// Выполняет вложенный прогон с кэшированием результата по ключу.
// Повторный вызов с тем же ключом возвращает результат первого прогона.
//
// Параметры:
//  Ключ             - Строка - Ключ кэша
//  ВключаемыеНаборы - Строка - Включающий фильтр имён наборов через запятую
//  КаталогиТестов   - Строка - Каталоги поиска тестов через запятую
//  ФайлыТестов      - Строка - Файлы тестов через запятую
//  ДопДетальки      - Соответствие из КлючИЗначение - Дополнительные детальки поделки:
//   * Ключ     - Строка - Имя детальки с префиксом "OneUnit.", например "OneUnit.ПутьКОтчетуJSON"
//   * Значение - Строка - Значение детальки
//
// Возвращаемое значение:
//  см. Прогнать
//
Функция ПрогнатьОднажды(Ключ, ВключаемыеНаборы, КаталогиТестов = "", ФайлыТестов = "", ДопДетальки = Неопределено) Экспорт

	Результат = КэшПрогонов.Получить(Ключ);

	Если Результат = Неопределено Тогда
		Результат = Прогнать(ВключаемыеНаборы, КаталогиТестов, ФайлыТестов, ДопДетальки);
		КэшПрогонов.Вставить(Ключ, Результат);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Возвращает имя временного файла, закреплённое за ключом.
// Повторный вызов с тем же ключом вернёт то же имя файла.
//
// Параметры:
//  Ключ       - Строка - Ключ кэша
//  Расширение - Строка - Расширение временного файла
//
// Возвращаемое значение:
//  Строка - Имя временного файла
//
Функция ВременныйПуть(Ключ, Расширение = "tmp") Экспорт

	Путь = КэшПутей.Получить(Ключ);

	Если Путь = Неопределено Тогда
		Путь = ВременныеФайлы.НовоеИмяФайла(Расширение);
		КэшПутей.Вставить(Ключ, Путь);
	КонецЕсли;

	Возврат Путь;

КонецФункции

// Читает накопленное содержимое потока перехваченного вывода
//
// Параметры:
//  Поток - ПотокВПамяти - Поток с перехваченным выводом
//
// Возвращаемое значение:
//  Строка - Содержимое потока
//
Функция ПрочитатьПоток(Поток) Экспорт

	Поток.СброситьБуферы();
	Поток.Перейти(0);

	ЧтениеТекста = Новый ЧтениеТекста();
	ЧтениеТекста.Открыть(Поток, Консоль.КодировкаВыходногоПотока);
	Результат = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Возврат Результат;

КонецФункции

// Ищет тестовый набор в тест плане по имени
//
// Параметры:
//  План - ТестПлан - Тест план
//  Имя  - Строка   - Имя набора
//
// Возвращаемое значение:
//  ОпределениеТестНабора - Найденный набор
//
Функция НайтиНабор(План, Имя) Экспорт

	Для каждого Набор Из План.Дети() Цикл
		Если Набор.Имя() = Имя Тогда
			Возврат Набор;
		КонецЕсли;
	КонецЦикла;

	ВызватьИсключение СтрШаблон("Не найден тестовый набор %1", Имя);

КонецФункции

// Ищет тест по имени среди детей набора или контейнера
//
// Параметры:
//  Родитель - ОпределениеТестНабора, ОпределениеТеста - Набор или контейнер
//  Имя      - Строка - Имя теста
//
// Возвращаемое значение:
//  ОпределениеТеста - Найденный тест
//
Функция НайтиТест(Родитель, Имя) Экспорт

	Для каждого Тест Из Родитель.Дети() Цикл
		Если Тест.Имя() = Имя Тогда
			Возврат Тест;
		КонецЕсли;
	КонецЦикла;

	ВызватьИсключение СтрШаблон("Не найден тест %1 в %2", Имя, Родитель.Имя());

КонецФункции

КэшПрогонов = Новый Соответствие;
КэшПутей    = Новый Соответствие;
