// Тесты служебного модуля ТестированиеСлужебный

#Использовать asserts
#Использовать collectionos
#Использовать ".."

&Тест
Процедура КраткоеОписаниеСодержитТекстОшибки() Экспорт

	Описание = ТестированиеСлужебный.КраткоеОписаниеОшибки(ПерехватитьИсключение("МояТестоваяОшибка"));

	Ожидаем.Что(СтрНайти(Описание, "МояТестоваяОшибка")).Больше(0);
	Ожидаем.Что(СтрНайти(Описание, "Стек трейс:")).Равно(0);

КонецПроцедуры

&Тест
Процедура КраткоеОписаниеУбираетМаркерУтверждения() Экспорт

	Попытка
		Утверждения.ПроверитьИстину(Ложь, "ТекстПроверкиУтверждения");
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
	КонецПопытки;

	Описание = ТестированиеСлужебный.КраткоеОписаниеОшибки(ИнформацияОбОшибке);

	Ожидаем.Что(СтрНайти(Описание, "ТекстПроверкиУтверждения")).Больше(0);
	Ожидаем.Что(СтрНайти(Описание, "[Failed]")).Равно(0);

КонецПроцедуры

&Тест
Процедура ПодробноеОписаниеСодержитПрефиксИМестоОшибки() Экспорт

	Описание = ТестированиеСлужебный.ПодробноеОписаниеОшибки(
		"МойПрефикс",
		ПерехватитьИсключение("МояПодробнаяОшибка")
	);

	Ожидаем.Что(СтрНайти(Описание, "МойПрефикс:")).Больше(0);
	Ожидаем.Что(СтрНайти(Описание, "МояПодробнаяОшибка")).Больше(0);
	Ожидаем.Что(СтрНайти(Описание, "ТестированиеСлужебныйТесты")).Больше(0);

КонецПроцедуры

&Тест
Процедура РазворачиваниеСпискаНаборовИзКаталоговИФайлов() Экспорт

	Файлы = ТестированиеСлужебный.РазвернутьСписокТестовыхНаборов(
		Массивы.ИзЭлементов("./tests/fixtures/execution"),
		Массивы.ИзЭлементов("./tests/fixtures/Тест.os"),
		Ложь
	);

	// 5 фикстур каталога execution + 1 явно переданный файл
	Ожидаем.Что(Файлы).ИмеетДлину(6);

КонецПроцедуры

&Тест
Процедура РазворачиваниеСпискаНаборовУчитываетРекурсию() Экспорт

	БезРекурсии = ТестированиеСлужебный.РазвернутьСписокТестовыхНаборов(
		Массивы.ИзЭлементов("./tests/support"),
		Массивы.ИзЭлементов(),
		Ложь
	);

	Ожидаем.Что(БезРекурсии).ИмеетДлину(0);

	СРекурсией = ТестированиеСлужебный.РазвернутьСписокТестовыхНаборов(
		Массивы.ИзЭлементов("./tests/support"),
		Массивы.ИзЭлементов(),
		Истина
	);

	Ожидаем.Что(СРекурсией).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ПерехватВыводаПоддерживаетВложенность() Экспорт

	ВнешнийПоток    = Новый ПотокВПамяти();
	ВнутреннийПоток = Новый ПотокВПамяти();

	// Сам тест выполняется под перехватом исполнителя,
	// так что вложенные перехваты начинаются со второго уровня
	ТестированиеСлужебный.НачатьПерехватВывода(ВнешнийПоток);
	Сообщить("ЗаписьВоВнешнийПоток");

	ТестированиеСлужебный.НачатьПерехватВывода(ВнутреннийПоток);
	Сообщить("ЗаписьВоВнутреннийПоток");
	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	// После завершения вложенного перехвата вывод должен вернуться
	// в объемлющий поток, а не в системную консоль
	Сообщить("ПовторнаяЗаписьВоВнешнийПоток");
	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	Внешний    = ПрочитатьПоток(ВнешнийПоток);
	Внутренний = ПрочитатьПоток(ВнутреннийПоток);

	Ожидаем.Что(СтрНайти(Внешний, "ЗаписьВоВнешнийПоток")).Больше(0);
	Ожидаем.Что(СтрНайти(Внешний, "ПовторнаяЗаписьВоВнешнийПоток")).Больше(0);
	Ожидаем.Что(СтрНайти(Внешний, "ЗаписьВоВнутреннийПоток")).Равно(0);

	Ожидаем.Что(СтрНайти(Внутренний, "ЗаписьВоВнутреннийПоток")).Больше(0);
	Ожидаем.Что(СтрНайти(Внутренний, "ЗаписьВоВнешнийПоток")).Равно(0);

КонецПроцедуры

Функция ПрочитатьПоток(Поток)

	Поток.СброситьБуферы();
	Поток.Перейти(0);

	ЧтениеТекста = Новый ЧтениеТекста();
	ЧтениеТекста.Открыть(Поток, Консоль.КодировкаВыходногоПотока);
	Результат = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Возврат Результат;

КонецФункции

Функция ПерехватитьИсключение(Текст)

	Попытка
		ВызватьИсключение Текст;
	Исключение
		Возврат ИнформацияОбОшибке();
	КонецПопытки;

КонецФункции
