// Тесты изоляции прогонов на уровне поделки.
//
// Внимание: у этого сценария намеренно нет конструктора с аннотацией &ТестовыйНабор,
// см. пояснение в Исполнитель.os - вложенные прогоны создают поделки.

#Использовать asserts
#Использовать "./support"
#Использовать ".."

&ПослеВсех
Процедура УдалитьВременныеФайлы() Экспорт
	ВременныеФайлы.Удалить();
КонецПроцедуры

&Тест
Процедура ИзолированныйНаборВыполняетсяВСвоейСреде() Экспорт

	Статистика = СтатистикаПрогона("ИзолированныйЗеленыйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(2);

КонецПроцедуры

&Тест
Процедура ПадениеОбнаруженияИзолированногоНабораНеРушитПрогон() Экспорт

	// Набор падает на обнаружении (неверный ключ JSON), но изоляция сдерживает
	// отказ: набор помечается сломанным, а прогон завершается штатно
	Статистика = СтатистикаПрогона("ИзолированныйБитыйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовСломано", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовОбнаружено", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура ИзолированныйНаборКонфигурируетсяСоветом() Экспорт

	// Лямбда совета отдает детальку "Изоляция.Значение", которую набор инжектит
	// и проверяет - так тест доказывает, что свежая поделка создана с советом
	Статистика = СтатистикаПрогона("ИзолированныйСоветныйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(0);

КонецПроцедуры

&Тест
Процедура ЯдовитыйИмпортУводитсяВДочернийПроцесс() Экспорт

	// Импорт из аннотации регистрирует два желудя с одним именем и ломает
	// создание любой поделки. Изоляция уровня "Процесс" подключает его только
	// в дочернем процессе, где тест и проверяет ожидаемый конфликт
	Статистика = СтатистикаПрогона("ИзолированныйПроцессныйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура СоветПереноситсяВДочернийПроцесс() Экспорт

	// Через границу процесса переезжает только текст лямбды совета - она
	// исполняется в дочернем процессе в контексте обнаруженного там набора.
	// Тест доказывает, что деталька из совета доехала до дочернего прогона
	Статистика = СтатистикаПрогона("ИзолированныйПроцессныйСоветныйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура РезультатыДочернегоПрогонаВклеиваютсяВПлан() Экспорт

	Прогон     = ПрогонПроцессногоКрасногоНабора();
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОшибка", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовОшибка", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура ПричиныКрасныхТестовПереносятсяИзДочернегоПрогона() Экспорт

	Прогон = ПрогонПроцессногоКрасногоНабора();

	Набор = ПрогоныТестов.НайтиНабор(Прогон.План, "ИзолированныйПроцессныйКрасныйНабор");
	Тест  = ПрогоныТестов.НайтиТест(Набор, "КрасныйТест");

	Результат = Прогон.Статистика.Результат(Тест);

	Ожидаем.Что(Результат.Состояние()).Равно(СостоянияВыполненияТестов.Ошибка);
	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "Специально падающее утверждение")).Больше(0);

КонецПроцедуры

&Тест
Процедура ИзолированныеТестыВыполняютсяВСвоихКонтекстах() Экспорт

	// Фикстура сама проверяет изоляцию: изолированные тесты не видят следов
	// соседних тестов, а обычный тест выполняется в общем потоке. Ассерты
	// зашиты в тесты фикстуры, снаружи проверяется только зеленый итог
	Статистика = СтатистикаПрогона("НаборСИзолированнымиТестами");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(5);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(5);

КонецПроцедуры

&Тест
Процедура ИмпортыНаУровнеПоделкиЛомаютОбнаружение() Экспорт

	Детальки = Новый Соответствие;
	Детальки.Вставить("OneUnit.КаталогиТестов", "");
	Детальки.Вставить("OneUnit.ФайлыТестов", "./tests/fixtures/broken/НаборСНевернойИзоляцией.os");

	Поделка = ПрогоныТестов.СоздатьПоделку(Детальки);

	Попытка
		Поделка.НайтиЖелудь("МенеджерТестирования").Обнаружить();
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
	КонецПопытки;

	Ожидаем.Что(ИнформацияОбОшибке).Не_().ЭтоНеопределено();
	Ожидаем.Что(СтрНайти(ИнформацияОбОшибке.Описание, "доступен только для уровня Процесс")).Больше(0);

КонецПроцедуры

&Тест
Процедура ЛямбдаСоветаВидитМетодыНабораВПроцессе() Экспорт

	// Экземпляр набора для захвата лямбдой поднимается в дочернем процессе
	// напрямую через Новый: многострочная лямбда с кавычками строит совет
	// вызовом экспортного метода набора
	Статистика = СтатистикаПрогона("ИзолированныйНаборССоветомИзМетода");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура СоветСОбъектомРаботаетВПроцессе() Экспорт

	// Лямбда совета исполняется в дочернем процессе по месту, поэтому детальки
	// совета не ограничены сериализуемостью - объект доступен набору как обычно
	Статистика = СтатистикаПрогона("ИзолированныйОбъектныйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура НеобнаруженныйДочернимПрогономНаборЛомаетсяСПояснением() Экспорт

	// Совет фикстуры подменяет детальку фильтра наборов, и дочерний прогон
	// не обнаруживает ни одного набора - причина набора объясняет, что произошло
	Прогон     = ПрогоныТестов.Прогнать("ИзолированныйНевидимыйНабор", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовСломано", 0)).Равно(1);

	Набор     = ПрогоныТестов.НайтиНабор(Прогон.План, "ИзолированныйНевидимыйНабор");
	Результат = Прогон.Статистика.Результат(Набор);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "не был обнаружен в дочернем прогоне")).Больше(0);

КонецПроцедуры

&Тест
Процедура НевыполненныйВДочернемПрогонеТестЛомаетсяСПояснением() Экспорт

	Прогон     = ПрогоныТестов.Прогнать("НаборСНевидимымИзолированнымТестом", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(1);

	Набор = ПрогоныТестов.НайтиНабор(Прогон.План, "НаборСНевидимымИзолированнымТестом");
	Тест  = ПрогоныТестов.НайтиТест(Набор, "НевидимыйТест");

	Результат = Прогон.Статистика.Результат(Тест);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "дочерний прогон не обнаружил набор")).Больше(0);

КонецПроцедуры

&Тест
Процедура ВыводДочернегоПроцессаНеРветВыводРодителя() Экспорт

	// Собственный лог дочернего прогона (детали упавших тестов, статистика)
	// не транслируется в консоль посреди вывода родителя: причины переносятся
	// структурно, а статистику выводит только сам родитель - один раз
	Вхождения = ЧислоВхожденийСтатистикиВВыводеПрогона("ИзолированныйПроцессныйКрасныйНабор");

	Ожидаем.Что(Вхождения).Равно(1);

КонецПроцедуры

&Тест
Процедура ВыводДочернейПоделкиНеРветВыводРодителя() Экспорт

	Вхождения = ЧислоВхожденийСтатистикиВВыводеПрогона("ИзолированныйПоделочныйКрасныйНабор");

	Ожидаем.Что(Вхождения).Равно(1);

КонецПроцедуры

&Тест
Процедура ИзолированныйНаборВклеиваетИтерацииКонтейнера() Экспорт

	// Повторяемый тест изолированного набора: итерации вклеиваются зеркалами
	Статистика = СтатистикаПрогона("ИзолированныйНаборСПовторяемымТестом");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(2);

КонецПроцедуры

&Тест
Процедура ПроцессныйКонтейнерВклеиваетИтерацииИзОтчета() Экспорт

	// Изолированный на уровне процесса повторяемый тест: итерации контейнера
	// вклеиваются в план родителя по записям отчета дочернего прогона
	Статистика = СтатистикаПрогона("НаборСПроцесснымПовторяемымТестом");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовОбнаружено", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(2);

КонецПроцедуры

&Тест
Процедура АварийныйДочернийПроцессЛомаетНаборСВыводом() Экспорт

	// Обнаружение в дочернем процессе падает, процесс умирает не сформировав
	// отчет - набор ломается с выводом дочернего прогона в причине
	Прогон     = ПрогоныТестов.Прогнать("ИзолированныйПроцессныйБитыйНабор", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовСломано", 0)).Равно(1);

	Набор     = ПрогоныТестов.НайтиНабор(Прогон.План, "ИзолированныйПроцессныйБитыйНабор");
	Результат = Прогон.Статистика.Результат(Набор);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "завершился аварийно")).Больше(0);

КонецПроцедуры

&Тест
Процедура ОбнаружениеБитогоПроцессногоНабораНеПадает() Экспорт

	План  = ПланОбнаружения("ИзолированныйПроцессныйБитыйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйПроцессныйБитыйНабор");

	Ожидаем.Что(Набор).Не_().ЭтоНеопределено();
	Ожидаем.Что(Набор.Дети().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура БитаяЛямбдаСоветаЛомаетТестНеРоняяПрогон() Экспорт

	// Поделочная лямбда падает в родителе, процессная - в точке входа ребенка:
	// оба теста ломаются с причинами, прогон продолжается
	Прогон     = ПрогоныТестов.Прогнать("НаборСБитойЛямбдойСовета", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(2);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовОбнаружено", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура ПроцессныйНаборВклеиваетИтерацииКонтейнера() Экспорт

	// Итерации повторяемого теста изолированного процессного набора
	// вклеиваются в план родителя из отчета дочернего прогона
	Статистика = СтатистикаПрогона("ИзолированныйПроцессныйПовторяемыйНабор");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(2);

КонецПроцедуры

&Тест
Процедура ОбнаружениеПоказываетКонтейнерПроцессногоНабора() Экспорт

	// Состав контейнера приезжает из плана дочернего обнаружения с итерациями
	План  = ПланОбнаружения("ИзолированныйПроцессныйПовторяемыйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйПроцессныйПовторяемыйНабор");

	Ожидаем.Что(Набор.Дети().Количество()).Равно(1);
	Ожидаем.Что(Набор.Дети().Получить(0).Дети().Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ПропускНабораПереноситсяИзДочернегоПрогона() Экспорт

	// Условие выключает набор только в изолированной среде: пропуск уровня
	// набора переносится из отчета дочернего прогона
	Прогон     = ПрогоныТестов.Прогнать("НаборПропускаемыйВИзоляции", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("НаборовПропущено", 0)).Равно(1);

	Набор     = ПрогоныТестов.НайтиНабор(Прогон.План, "НаборПропускаемыйВИзоляции");
	Результат = Прогон.Статистика.Результат(Набор);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "Набор пропускается в изолированной среде")).Больше(0);

КонецПроцедуры

&Тест
Процедура ИзолированныеТестыНаследуютПадениеНабораВИзоляции() Экспорт

	// ПередВсеми фикстуры падает только в изолированной среде: обычный тест
	// зеленый, а изолированные наследуют состояние и причины сломанного набора
	Прогон     = ПрогоныТестов.Прогнать("НаборПадающийВИзоляции", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовСломано", 0)).Равно(2);

	Набор = ПрогоныТестов.НайтиНабор(Прогон.План, "НаборПадающийВИзоляции");
	Тест  = ПрогоныТестов.НайтиТест(Набор, "ПроцессныйНаследуетПадениеНабора");

	Результат = Прогон.Статистика.Результат(Тест);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "ПередВсеми падает в изолированной среде")).Больше(0);

КонецПроцедуры

&Тест
Процедура ПустойСоветНеЛомаетИзолированныйНабор() Экспорт

	Статистика = СтатистикаПрогона("ИзолированныйНаборСПустымСоветом");

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);

КонецПроцедуры

&Тест
Процедура ПропускПереноситсяИзДочернегоПрогона() Экспорт

	Прогон     = ПрогоныТестов.Прогнать("ИзолированныйПроцессныйНаборСПропуском", "./tests/fixtures/isolation");
	Статистика = Прогон.Статистика.СтатистикаТестПлана();

	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовУспешно", 0)).Равно(1);
	Ожидаем.Что(Статистика.ПолучитьИлиУмолчание("ТестовПропущено", 0)).Равно(1);

	Набор = ПрогоныТестов.НайтиНабор(Прогон.План, "ИзолированныйПроцессныйНаборСПропуском");
	Тест  = ПрогоныТестов.НайтиТест(Набор, "ВыключенныйВПроцессе");

	Результат = Прогон.Статистика.Результат(Тест);

	Ожидаем.Что(СтрНайти(Результат.ОписанияПричин().Получить(0), "Пропуск переносится из дочернего прогона")).Больше(0);

КонецПроцедуры

&Тест
Процедура ОбнаружениеНевидимогоНабораОставляетЕгоПустым() Экспорт

	// Дочернее обнаружение не нашло набор (совет подменил фильтр) -
	// обнаружение не падает, набор остается пустым плейсхолдером
	План  = ПланОбнаружения("ИзолированныйНевидимыйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйНевидимыйНабор");

	Ожидаем.Что(Набор.Дети().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ИзолированныйПроцессПишетСтатистикуПокрытия() Экспорт

	// При прогоне с покрытием изолированный дочерний процесс получает -codestat
	// и складывает статистику в каталог родительского прогона, который мержит
	// ее в общие отчеты покрытия.
	// Каталог - через собственный менеджер: глобальный модуль ВременныеФайлы
	// зачищается построителем декоратора при каждом создании поделки
	МенеджерВременныхФайлов = Новый МенеджерВременныхФайлов();
	КаталогСтатистики = МенеджерВременныхФайлов.СоздатьКаталог();

	ДопДетальки = Новый Соответствие;
	ДопДетальки.Вставить("OneUnit.КаталогСтатистикиПокрытия", КаталогСтатистики);

	ПрогоныТестов.Прогнать("ИзолированныйПроцессныйКрасныйНабор", "./tests/fixtures/isolation", "", ДопДетальки);

	КоличествоСтатистик = НайтиФайлы(КаталогСтатистики, "stat_*.json").Количество();
	МенеджерВременныхФайлов.Удалить();

	Ожидаем.Что(КоличествоСтатистик).Больше(0);

КонецПроцедуры

&Тест
Процедура ОбнаружениеПоказываетСоставИзолированногоНабора() Экспорт

	// Чистое обнаружение (без исполнения) разворачивает изолированный набор
	// в его среде - внешний тулинг видит фактический состав тестов
	План  = ПланОбнаружения("ИзолированныйЗеленыйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйЗеленыйНабор");

	Ожидаем.Что(Набор.Дети().Количество()).Равно(2);
	Ожидаем.Что(ПрогоныТестов.НайтиТест(Набор, "ПервыйЗеленый")).Не_().ЭтоНеопределено();
	Ожидаем.Что(ПрогоныТестов.НайтиТест(Набор, "ВторойЗеленый")).Не_().ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура ОбнаружениеПоказываетСоставПроцессногоНабора() Экспорт

	// Состав приезжает из дочернего процесса обнаружения, тесты не исполняются -
	// красный тест набора виден в плане, но прогон обнаружения зеленый
	План  = ПланОбнаружения("ИзолированныйПроцессныйКрасныйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйПроцессныйКрасныйНабор");

	Ожидаем.Что(Набор.Дети().Количество()).Равно(2);
	Ожидаем.Что(ПрогоныТестов.НайтиТест(Набор, "КрасныйТест")).Не_().ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура ОбнаружениеБитогоИзолированногоНабораНеПадает() Экспорт

	План  = ПланОбнаружения("ИзолированныйБитыйНабор");
	Набор = ПрогоныТестов.НайтиНабор(План, "ИзолированныйБитыйНабор");

	Ожидаем.Что(Набор).Не_().ЭтоНеопределено();
	Ожидаем.Что(Набор.Дети().Количество()).Равно(0);

КонецПроцедуры

Функция ПланОбнаружения(Знач ВключаемыеНаборы)

	Детальки = Новый Соответствие;
	Детальки.Вставить("OneUnit.КаталогиТестов", "./tests/fixtures/isolation");
	Детальки.Вставить("OneUnit.ФайлыТестов", "");
	Детальки.Вставить("OneUnit.ТестовыеНаборыВключаемые", ВключаемыеНаборы);

	Поделка = ПрогоныТестов.СоздатьПоделку(Детальки);

	Возврат Поделка.НайтиЖелудь("МенеджерТестирования").Обнаружить();

КонецФункции

Функция СтатистикаПрогона(Знач ВключаемыеНаборы)

	Возврат ПрогоныТестов.Прогнать(
		ВключаемыеНаборы,
		"./tests/fixtures/isolation"
	).Статистика.СтатистикаТестПлана();

КонецФункции

Функция ПрогонПроцессногоКрасногоНабора()

	Возврат ПрогоныТестов.ПрогнатьОднажды(
		"ПроцессныйКрасныйНабор",
		"ИзолированныйПроцессныйКрасныйНабор",
		"./tests/fixtures/isolation"
	);

КонецФункции

Функция ЧислоВхожденийСтатистикиВВыводеПрогона(Знач ВключаемыеНаборы)

	ПотокВывода = Новый ПотокВПамяти();
	ТестированиеСлужебный.НачатьПерехватВывода(ПотокВывода);

	Попытка
		ПрогоныТестов.Прогнать(ВключаемыеНаборы, "./tests/fixtures/isolation");
	Исключение
		ТестированиеСлужебный.ЗавершитьПерехватВывода();
		ВызватьИсключение;
	КонецПопытки;

	ТестированиеСлужебный.ЗавершитьПерехватВывода();

	Вывод = ПрогоныТестов.ПрочитатьПоток(ПотокВывода);

	Возврат ЧислоВхождений(Вывод, "Запуск тестов завершился");

КонецФункции

Функция ЧислоВхождений(Знач Текст, Знач Подстрока)

	Вхождения = 0;
	Позиция   = СтрНайти(Текст, Подстрока);

	Пока Позиция > 0 Цикл
		Вхождения = Вхождения + 1;
		Позиция   = СтрНайти(Текст, Подстрока, НаправлениеПоиска.СНачала, Позиция + СтрДлина(Подстрока));
	КонецЦикла;

	Возврат Вхождения;

КонецФункции
