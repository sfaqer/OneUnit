// Тесты MCP-инструментов (src/mcp): сборка деталек прогона, разбор
// JSONL-вывода и чтение JSON-отчета прогона (РепортерJSON).
//
// Внимание: у этого сценария намеренно нет конструктора с аннотацией &ТестовыйНабор,
// см. пояснение в Исполнитель.os

#Использовать asserts
#Использовать tempfiles
#Использовать collectionos
#Использовать logos
#Использовать "./support"
#Использовать "../src/cli/internal"
#Использовать "../src/mcp/internal"

&ПослеВсех
Процедура УдалитьВременныеФайлы() Экспорт
	ВременныеФайлы.Удалить();
КонецПроцедуры

#Область ТестыДеталекФильтров

&Тест
Процедура ДеталькиФильтровЗаполняютсяПереданнымиЗначениями() Экспорт

	Каталоги = Новый Массив;
	Каталоги.Добавить("./tests");
	Каталоги.Добавить("./more");

	Теги = Новый Массив;
	Теги.Добавить("smoke");

	Детальки = Служебный().ДеталькиФильтров(
		Каталоги,
		Неопределено,
		Истина,
		Теги,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено
	);

	Ожидаем.Что(Детальки.Получить("КаталогиТестов")).ИмеетДлину(2);
	Ожидаем.Что(Детальки.Получить("КаталогиТестов")[1]).Равно("./more");
	Ожидаем.Что(Детальки.Получить("ФайлыТестов")).ИмеетДлину(0);
	Ожидаем.Что(Детальки.Получить("ИскатьВПодкаталогах")).ЭтоИстина();
	Ожидаем.Что(Детальки.Получить("ТегиВключаемые")).ИмеетДлину(1);
	Ожидаем.Что(Детальки.Получить("ТестовыеНаборыВключаемые")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ПризнакПоискаВПодкаталогахПоУмолчаниюЛожь() Экспорт

	Детальки = Служебный().ДеталькиФильтров(
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено
	);

	Ожидаем.Что(Детальки.Получить("ИскатьВПодкаталогах")).ЭтоЛожь();

КонецПроцедуры

&Тест
Процедура ПустыеЗначенияФильтровОтбрасываются() Экспорт

	Файлы = Новый Массив;
	Файлы.Добавить("");
	Файлы.Добавить("./tests/Тест.os");
	Файлы.Добавить(Неопределено);

	Детальки = Служебный().ДеталькиФильтров(
		Неопределено,
		Файлы,
		Ложь,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено
	);

	Ожидаем.Что(Детальки.Получить("ФайлыТестов")).ИмеетДлину(1);
	Ожидаем.Что(Детальки.Получить("ФайлыТестов")[0]).Равно("./tests/Тест.os");

КонецПроцедуры

#КонецОбласти

#Область ТестыРазбораВыводаПрогона

&Тест
Процедура ЗначенияПоляЛогаИзвлекаютсяИзJSONLВывода() Экспорт

	Вывод = "{""msg"":"""",""ИмяТеста"":""Набор.Тест1""}" + Символы.ПС
		+ "строка не в формате JSON" + Символы.ПС
		+ "{""msg"":""сообщение без имени теста""}" + Символы.ПС
		+ "{""msg"":"""",""ИмяТеста"":""Набор.Тест2""}";

	Тесты = Служебный().ЗначенияПоляЛога(Вывод, "ИмяТеста");

	Ожидаем.Что(Тесты).ИмеетДлину(2);
	Ожидаем.Что(Тесты[0]).Равно("Набор.Тест1");
	Ожидаем.Что(Тесты[1]).Равно("Набор.Тест2");

КонецПроцедуры

&Тест
Процедура ТекстВыводаСодержитСообщенияЛогаИПрочиеСтроки() Экспорт

	Вывод = "{""msg"":""Сообщение лога"",""level"":""INFO""}" + Символы.ПС
		+ "Ошибка компиляции сценария" + Символы.ПС
		+ "   " + Символы.ПС
		+ "{""msg"":""""}";

	Текст = Служебный().ТекстВывода(Вывод);

	Ожидаем.Что(Текст).Равно("Сообщение лога" + Символы.ПС + "Ошибка компиляции сценария");

КонецПроцедуры

&Тест
Процедура СтрокаПохожаяНаJSONНоБитаяПропускается() Экспорт

	Вывод = "{битая строка не в формате JSON" + Символы.ПС
		+ "{""msg"":"""",""ИмяТеста"":""Набор.Тест""}";

	Тесты = Служебный().ЗначенияПоляЛога(Вывод, "ИмяТеста");

	Ожидаем.Что(Тесты).ИмеетДлину(1);
	Ожидаем.Что(Тесты[0]).Равно("Набор.Тест");

КонецПроцедуры

#КонецОбласти

#Область ТестыВыполненияПрогонов

&Тест
Процедура ТестированиеФормируетОтчетJSON() Экспорт

	ПутьКОтчету = ВременныеФайлы.НовоеИмяФайла("json");

	Детальки = Служебный().ДеталькиФильтров(
		Неопределено,
		Массивы.ИзЭлементов("./tests/fixtures/Тест.os"),
		Ложь,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено
	);

	Результат = Служебный().ВыполнитьТестирование(Детальки, 0, ПутьКОтчету, Неопределено);

	Ожидаем.Что(Результат.КодВозврата).Равно(0);

	Отчет = Служебный().ПрочитатьОтчет(ПутьКОтчету);

	Ожидаем.Что(Отчет).Не_().ЭтоНеопределено();
	Ожидаем.Что(Отчет.statistics.total).Равно(2);

КонецПроцедуры

&Тест
Процедура ОбнаружениеВозвращаетИменаТестовВВыводе() Экспорт

	Детальки = Служебный().ДеталькиФильтров(
		Неопределено,
		Массивы.ИзЭлементов("./tests/fixtures/Тест.os"),
		Ложь,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено,
		Неопределено
	);

	Результат = Служебный().ВыполнитьОбнаружение(Детальки, Неопределено);

	Ожидаем.Что(Результат.КодВозврата).Равно(0);

	Тесты = Служебный().ЗначенияПоляЛога(Результат.Вывод, "ИмяТеста");

	Ожидаем.Что(Тесты).ИмеетДлину(2);
	Ожидаем.Что(Тесты[0]).Равно("Тест.Тест1");

КонецПроцедуры

#КонецОбласти

#Область ТестыОтчетаJSON

&Тест
Процедура БезФайлаОтчетаВозвращаетсяНеопределено() Экспорт

	Отчет = Служебный().ПрочитатьОтчет(ВременныеФайлы.НовоеИмяФайла("json"));

	Ожидаем.Что(Отчет).ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура СтатистикаЧитаетсяИзОтчета() Экспорт

	Статистика = Отчет().statistics;

	Ожидаем.Что(Статистика.total).Равно(4);
	Ожидаем.Что(Статистика.passed).Равно(2);
	Ожидаем.Что(Статистика.failed).Равно(1);
	Ожидаем.Что(Статистика.broken).Равно(1);
	Ожидаем.Что(Статистика.skipped).Равно(0);
	Ожидаем.Что(Статистика.aborted).Равно(0);

КонецПроцедуры

&Тест
Процедура УпавшийТестПопадаетВПроблемыСПричиной() Экспорт

	Проблема = Проблема(Отчет(), "СостояниеОшибка");

	Ожидаем.Что(Проблема).Не_().ЭтоНеопределено();
	Ожидаем.Что(Проблема.status).Равно("failed");
	Ожидаем.Что(Проблема.suite).Равно("НаборКрасныхТестов");
	Ожидаем.Что(СтрНайти(Проблема.message, "Ошибка утверждения")).Больше(0);
	Ожидаем.Что(СтрНайти(Проблема.details, "НаборКрасныхТестов.os")).Больше(0);

КонецПроцедуры

&Тест
Процедура СломанныйТестПопадаетВПроблемыСоСтатусомBroken() Экспорт

	Проблема = Проблема(Отчет(), "СостояниеСломан");

	Ожидаем.Что(Проблема).Не_().ЭтоНеопределено();
	Ожидаем.Что(Проблема.status).Равно("broken");
	Ожидаем.Что(СтрНайти(Проблема.message, "Сломано")).Больше(0);

КонецПроцедуры

&Тест
Процедура СломанныйНаборПопадаетВПроблемыБезИмениТеста() Экспорт

	Проблема = ПроблемаНабора(Отчет(), "НаборПадающийВКонструкторе");

	Ожидаем.Что(Проблема).Не_().ЭтоНеопределено();
	Ожидаем.Что(Проблема.status).Равно("broken");
	Ожидаем.Что(Проблема.Свойство("test")).ЭтоЛожь();
	Ожидаем.Что(СтрНайти(Проблема.details, "Не удаётся инстанцировать")).Больше(0);

КонецПроцедуры

&Тест
Процедура ВыключенныйТестПопадаетВПропущенные() Экспорт

	Пропуск = Пропуск(ОтчетСПропусками(), "НаборСВыключеннымиТестами", "Выключен");

	Ожидаем.Что(Пропуск).Не_().ЭтоНеопределено();
	Ожидаем.Что(Пропуск.status).Равно("skipped");
	Ожидаем.Что(СтрНайти(Пропуск.reason, "На мне аннотация Выключен")).Больше(0);

КонецПроцедуры

&Тест
Процедура ВыключенныйНаборПопадаетВПропущенныеЦеликом() Экспорт

	Пропуск = Пропуск(ОтчетСПропусками(), "НаборВыключенный", Неопределено);

	Ожидаем.Что(Пропуск).Не_().ЭтоНеопределено();
	Ожидаем.Что(Пропуск.status).Равно("skipped");

КонецПроцедуры

&Тест
Процедура ПрерванныеТестыИКонтейнерыПолучаютСтатусAborted() Экспорт

	Отчет = ОтчетСПропусками();

	// Одиночный прерванный тест
	Пропуск = Пропуск(Отчет, "НаборСПрерваннымиТестами", "ПрерванныйТест");

	Ожидаем.Что(Пропуск).Не_().ЭтоНеопределено();
	Ожидаем.Что(Пропуск.status).Равно("aborted");
	Ожидаем.Что(СтрНайти(Пропуск.reason, "Я прервался")).Больше(0);

	// Итерация прерванного повторяемого теста разворачивается в отдельный тест,
	// набором указывается ближайший тестовый набор, а не контейнер итераций
	ПропускИтерации = Пропуск(Отчет, "НаборСПрерваннымиТестами", "Повторение 3 из 4");

	Ожидаем.Что(ПропускИтерации).Не_().ЭтоНеопределено();
	Ожидаем.Что(ПропускИтерации.status).Равно("aborted");

КонецПроцедуры

&Тест
Процедура УспешныеКонтейнерыНеПопадаютВОтчет() Экспорт

	Отчет = ОтчетСПропусками();

	Ожидаем.Что(Отчет.problems).ИмеетДлину(0);

	Для Каждого Пропуск Из Отчет.skipped_tests Цикл
		Ожидаем.Что(СтрНайти(Пропуск.suite, "ПовторяемыйТест")).Равно(0);
	КонецЦикла;

КонецПроцедуры

&Тест
Процедура РепортерБезПутиКОтчетуНичегоНеПишет() Экспорт

	// Поделка без прогона: репортер еще не создан рогаткой тестирования
	Детальки = Новый Соответствие;
	Детальки.Вставить("OneUnit.КаталогиТестов", "");
	Детальки.Вставить("OneUnit.ФайлыТестов", "");

	Поделка = ПрогоныТестов.СоздатьПоделку(Детальки);

	Репортер = Поделка.НайтиЖелудь("РепортерJSON", Массивы.ИзЭлементов(""));

	// Репортер без пути к отчету игнорирует событие, не обращаясь к тест-плану
	Репортер.ИсполнениеТестПланКонец(Неопределено);

	Ожидаем.Что(Истина).ЭтоИстина();

КонецПроцедуры

#КонецОбласти

#Область ТестыСводкиПокрытия

&Тест
Процедура БезФайлаПокрытияВозвращаетсяНеопределено() Экспорт

	Сводка = Служебный().СводкаПокрытия(ВременныеФайлы.НовоеИмяФайла("xml"));

	Ожидаем.Что(Сводка).ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура ПустойОтчетПокрытияДаетСтопроцентноеПокрытие() Экспорт

	ПутьКОтчету = ВременныеФайлы.НовоеИмяФайла("xml");

	ЗаписьТекста = Новый ЗаписьТекста(ПутьКОтчету);
	ЗаписьТекста.Записать("<coverage version=""1""/>");
	ЗаписьТекста.Закрыть();

	Сводка = Служебный().СводкаПокрытия(ПутьКОтчету);

	Ожидаем.Что(Сводка.percent).Равно(100);
	Ожидаем.Что(Сводка.lines_total).Равно(0);
	Ожидаем.Что(Сводка.files).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СводкаПокрытияСчитаетПроцентыИНепокрытыеСтроки() Экспорт

	ПутьКОтчету = ВременныеФайлы.НовоеИмяФайла("xml");

	ТекстОтчета =
		"<coverage version=""1"">
		|<file path=""src/Полностью.os"">
		|<lineToCover lineNumber=""1"" covered=""true""/>
		|<lineToCover lineNumber=""2"" covered=""true""/>
		|</file>
		|<file path=""src/Наполовину.os"">
		|<lineToCover lineNumber=""3"" covered=""true""/>
		|<lineToCover lineNumber=""7"" covered=""false""/>
		|</file>
		|</coverage>";

	ЗаписьТекста = Новый ЗаписьТекста(ПутьКОтчету);
	ЗаписьТекста.Записать(ТекстОтчета);
	ЗаписьТекста.Закрыть();

	Сводка = Служебный().СводкаПокрытия(ПутьКОтчету);

	Ожидаем.Что(Сводка.lines_total).Равно(4);
	Ожидаем.Что(Сводка.lines_covered).Равно(3);
	Ожидаем.Что(Сводка.percent).Равно(75);

	Файлы = Сводка.files;

	Ожидаем.Что(Файлы).ИмеетДлину(2);

	// Наименее покрытый файл - первый
	Ожидаем.Что(Файлы[0].file).Равно("src/Наполовину.os");
	Ожидаем.Что(Файлы[0].percent).Равно(50);
	Ожидаем.Что(Файлы[0].uncovered_lines).ИмеетДлину(1);
	Ожидаем.Что(Файлы[0].uncovered_lines[0]).Равно(7);

	Ожидаем.Что(Файлы[1].file).Равно("src/Полностью.os");
	Ожидаем.Что(Файлы[1].percent).Равно(100);
	Ожидаем.Что(Файлы[1].Свойство("uncovered_lines")).ЭтоЛожь();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеМетоды

Функция Служебный()

	// Вне поделки MCP-сервера желудь собирается вручную
	Возврат Новый MCPИнструментыСлужебный(
		Новый ЗапускательТестирования(Новый КонсольноеПриложениеТестированиеСлужебный()),
		Логирование.ПолучитьЛог("oscript.lib.oneunit.тесты")
	);

КонецФункции

Функция Отчет()

	ПутьКОтчету = ПрогоныТестов.ВременныйПуть("MCPОтчетJSON", "json");

	ДопДетальки = Новый Соответствие;
	ДопДетальки.Вставить("OneUnit.ПутьКОтчетуJSON", ПутьКОтчету);

	ФайлыТестов = Новый Массив;
	ФайлыТестов.Добавить("./tests/fixtures/Тест.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборКрасныхТестов.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборПадающийВКонструкторе.os");

	ПрогоныТестов.ПрогнатьОднажды(
		"MCPОтчетJSON",
		"Тест,НаборКрасныхТестов,НаборПадающийВКонструкторе",
		"",
		СтрСоединить(ФайлыТестов, ","),
		ДопДетальки
	);

	Возврат Служебный().ПрочитатьОтчет(ПутьКОтчету);

КонецФункции

Функция ПрогонСПропусками()

	ДопДетальки = Новый Соответствие;
	ДопДетальки.Вставить(
		"OneUnit.ПутьКОтчетуJSON",
		ПрогоныТестов.ВременныйПуть("MCPОтчетJSONПропуски", "json")
	);

	ФайлыТестов = Новый Массив;
	ФайлыТестов.Добавить("./tests/fixtures/НаборСВыключеннымиТестами.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборВыключенный.os");
	ФайлыТестов.Добавить("./tests/fixtures/НаборСПрерваннымиТестами.os");
	ФайлыТестов.Добавить("./tests/fixtures/ПовторяемыйТест.os");

	Возврат ПрогоныТестов.ПрогнатьОднажды(
		"MCPОтчетJSONПропуски",
		"НаборСВыключеннымиТестами,НаборВыключенный,НаборСПрерваннымиТестами,ПовторяемыйТест",
		"",
		СтрСоединить(ФайлыТестов, ","),
		ДопДетальки
	);

КонецФункции

Функция ОтчетСПропусками()

	ПрогонСПропусками();

	Возврат Служебный().ПрочитатьОтчет(
		ПрогоныТестов.ВременныйПуть("MCPОтчетJSONПропуски", "json")
	);

КонецФункции

Функция Пропуск(Отчет, Знач ИмяНабора, Знач ИмяТеста)

	Для Каждого Пропуск Из Отчет.skipped_tests Цикл

		Если Пропуск.suite = ИмяНабора И ЗначениеСвойства(Пропуск, "test") = ИмяТеста Тогда
			Возврат Пропуск;
		КонецЕсли;

	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция Проблема(Отчет, Знач ИмяТеста)

	Для Каждого Проблема Из Отчет.problems Цикл
		Если ЗначениеСвойства(Проблема, "test") = ИмяТеста Тогда
			Возврат Проблема;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция ПроблемаНабора(Отчет, Знач ИмяНабора)

	Для Каждого Проблема Из Отчет.problems Цикл
		Если Проблема.suite = ИмяНабора И НЕ Проблема.Свойство("test") Тогда
			Возврат Проблема;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция ЗначениеСвойства(Запись, Знач ИмяСвойства)

	Значение = Неопределено;
	Запись.Свойство(ИмяСвойства, Значение);

	Возврат Значение;

КонецФункции

#КонецОбласти
